generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Alumnos {
  matricula       Int    @id @default(autoincrement())
  nombreCompleto  String @db.VarChar(255)
  apellidoPaterno String @db.VarChar(255)
  apellidoMaterno String @db.VarChar(255)
  nombres         String @db.VarChar(255)
  genero          String @db.VarChar(255)
  nacimiento      String @db.VarChar(255)
  grupo           String @db.VarChar(255)
  telefono        String @db.VarChar(255)
  correo          String @db.VarChar(255)
  plantel         String @db.VarChar(255)
  contratos       String @db.LongText

  @@map("alumnos")
}

model Familias {
  id          Int      @id @default(autoincrement())
  apellidos   String   @db.VarChar(255)
  tutor       String   @db.VarChar(255)
  telefono    String?  @db.VarChar(255)
  correo      String?  @db.VarChar(255)

  @@map("familias")
}

model Base {
  id              Int      @id @default(autoincrement())
  matricula       String   @db.VarChar(255)
  nombreCompleto  String   @db.VarChar(255)
  apellidoPaterno String   @db.VarChar(255)
  apellidoMaterno String   @db.VarChar(255)
  nombres         String   @db.VarChar(255)
  genero          Boolean  @default(true)
  fechaNacimiento String   @map("Fecha de nacimiento") @db.VarChar(255)
  plantel         String   @db.VarChar(255)
  nivel           String   @db.VarChar(255)
  grado           String   @db.VarChar(255)
  grupo           String   @db.VarChar(255)
  padreTutor      String   @map("Nombre del padre o tutor") @db.VarChar(255)
  telefono        String   @db.VarChar(255)
  correo          String   @db.VarChar(255)
  usuario         String   @db.VarChar(255)
  estatus         String   @default("Activo") @db.VarChar(255)
  contingencia    Boolean? @default(false)
  ciclo           String?  @db.VarChar(255)
  interno         Boolean? @default(true)

  @@map("base")
}

model AlumnoMatriculaLinks {
  id                  Int      @id @default(autoincrement())
  previous_matricula  String   @unique(map: "uniq_previous_matricula") @db.VarChar(255)
  successor_matricula String   @unique(map: "uniq_successor_matricula") @db.VarChar(255)
  created_at          DateTime @default(now()) @db.DateTime(0)
  updated_at          DateTime @updatedAt @db.DateTime(0)

  @@index([previous_matricula, successor_matricula], map: "idx_matricula_link_pair")
  @@map("alumno_matricula_links")
}

model StudentCustomSections {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(120)
  plantel     String   @default("global") @db.VarChar(255)
  description String?  @db.VarChar(255)
  color       String?  @db.VarChar(32)
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.DateTime(0)
  updated_at  DateTime @updatedAt @db.DateTime(0)

  @@unique([plantel, name], map: "uniq_student_custom_section_scope_name")
  @@index([plantel, is_active, sort_order], map: "idx_student_custom_sections_scope")
  @@map("student_custom_sections")
}

model StudentCustomSectionMemberships {
  id         Int      @id @default(autoincrement())
  section_id Int
  matricula  String   @db.VarChar(255)
  created_at DateTime @default(now()) @db.DateTime(0)
  created_by String?  @db.VarChar(255)

  @@unique([section_id, matricula], map: "uniq_student_custom_section_member")
  @@index([matricula], map: "idx_student_custom_section_member_matricula")
  @@map("student_custom_section_memberships")
}

model StudentFamilyLinks {
  id         Int      @id @default(autoincrement())
  family_key String   @db.VarChar(255)
  matricula  String   @unique(map: "uniq_student_family_member") @db.VarChar(255)
  created_at DateTime @default(now()) @db.DateTime(0)
  updated_at DateTime @updatedAt @db.DateTime(0)

  @@index([family_key], map: "idx_student_family_key")
  @@map("student_family_links")
}

model Becas {
  id         Int    @id @default(autoincrement())
  concepto   String @unique(map: "id") @db.VarChar(255)
  porcentaje Int
  plantel    String @default("global") @db.VarChar(255)
  autor      String @db.VarChar(255)

  @@map("becas")
}

model CiclosEscolares {
  id            Int     @id @default(autoincrement())
  ciclo_escolar String? @db.VarChar(255)

  @@map("ciclos_escolares")
}

model Conceptos {
  id          Int     @id @default(autoincrement())
  concepto    String  @db.VarChar(255)
  costo       Int
  description String? @db.VarChar(255)
  plantel     String  @default("global") @db.VarChar(255)
  eventual    Boolean @default(true)
  plazo       String  @default("[1]") @db.VarChar(255)
  ciclo       String  @db.VarChar(255)

  @@map("conceptos")
}

model Documentos {
  documento      Int      @id @default(autoincrement())
  concepto       String   @db.VarChar(255)
  conceptoNombre String   @db.VarChar(255)
  matricula      String   @db.VarChar(255)
  costo          Int
  plazo          String   @db.Text
  meses          String?  @default("1") @db.VarChar(11)
  anual          Int?
  beca           String?  @db.VarChar(255)
  becaNombre     String?  @db.VarChar(255)
  fecha          DateTime @default(now()) @db.DateTime(0)
  ciclo          String   @default("2025") @db.VarChar(255)
  eventual       Boolean  @default(false)
  responsable    String   @db.VarChar(255)
  estatus        String   @default("Vigente") @db.VarChar(255)
  contingencia   Boolean? @default(false)

  @@map("documentos")
}

model Facturas {
  id            Int       @id @default(autoincrement())
  matricula     String    @db.VarChar(50)
  rfc           String    @db.VarChar(20)
  razonSocial   String    @db.VarChar(255)
  regimenFiscal String?   @db.VarChar(10)
  usoCfdi       String?   @db.VarChar(10)
  cp            String?   @db.VarChar(10)
  correo        String?   @db.VarChar(255)
  total         Decimal   @db.Decimal(10, 2)
  folios        String    @db.Text
  fecha         DateTime? @default(now()) @db.DateTime(0)

  @@map("facturas")
}

model FormasPago {
  id    Int    @id @default(autoincrement())
  forma String @db.VarChar(255)

  @@map("formaspago")
}

model Modificadores {
  id          Int      @id @default(autoincrement())
  documento   Int
  mes         String?  @db.VarChar(255)
  recargo     Boolean? @default(false)
  formaDePago Int?
  uid         String?  @unique(map: "id") @db.VarChar(255)

  @@map("modificadores")
}

model Notificaciones {
  id        Int      @id @default(autoincrement())
  fecha     DateTime @default(now()) @db.DateTime(0)
  mensaje   String   @db.VarChar(255)
  usuarioId Int
  leido     Boolean  @default(false)

  @@map("notificaciones")
}

model Preview {
  folio          Int      @id @unique(map: "folio") @default(autoincrement())
  folio_plantel  String?  @db.VarChar(255)
  fecha          DateTime @default(now()) @db.Timestamp(0)
  matricula      String   @db.VarChar(255)
  documento      Int
  mes            String   @db.VarChar(255)
  mesReal        String?  @db.VarChar(50)
  nombreCompleto String   @db.VarChar(255)
  concepto       String   @db.VarChar(255)
  conceptoNombre String   @db.VarChar(255)
  monto          Decimal  @db.Decimal(65, 2)
  montoLetra     String   @db.VarChar(255)
  importeTotal   Decimal  @db.Decimal(65, 2)
  saldoAntes     Decimal  @db.Decimal(65, 2)
  saldoDespues   Decimal  @db.Decimal(65, 2)
  pagos          Decimal  @db.Decimal(65, 2)
  pagosDespues   Decimal  @db.Decimal(65, 2)
  recargo        Boolean  @default(false)
  referencia     String?  @db.VarChar(255)
  usuario        String   @db.VarChar(255)
  usuarioId      Int?
  formaDePago    String   @db.VarChar(255)
  plantel        String?  @db.VarChar(50)
  instituto      String?  @default("1") @db.VarChar(55)
  ciclo          String   @default("2025-2026") @db.VarChar(255)
  estatus        String   @default("Vigente") @db.VarChar(255)
  cancelada_por  String?  @db.VarChar(255)
  base64         Bytes?
  filename       String?  @db.VarChar(255)

  @@map("preview")
}

model ReferenciasDePago {
  folio          Int      @id @unique(map: "folio") @default(autoincrement())
  fecha          DateTime @default(now()) @db.Timestamp(0)
  matricula      String   @db.VarChar(255)
  documento      Int
  mes            String   @db.VarChar(255)
  mesReal        String?  @db.VarChar(50)
  nombreCompleto String   @db.VarChar(255)
  concepto       String   @db.VarChar(255)
  conceptoNombre String   @db.VarChar(255)
  monto          Decimal  @db.Decimal(65, 2)
  montoLetra     String   @db.VarChar(255)
  importeTotal   Decimal  @db.Decimal(65, 2)
  saldoAntes     Decimal  @db.Decimal(65, 2)
  saldoDespues   Decimal  @db.Decimal(65, 2)
  pagos          Decimal  @db.Decimal(65, 2)
  pagosDespues   Decimal  @db.Decimal(65, 2)
  recargo        Boolean  @default(false)
  referencia     String?  @db.VarChar(255)
  usuario        String   @db.VarChar(255)
  usuarioId      Int?
  formaDePago    String   @db.VarChar(255)
  plantel        String?  @db.VarChar(50)
  instituto      Boolean? @default(true)
  ciclo          String   @default("2025") @db.VarChar(255)
  estatus        String   @default("Vigente") @db.VarChar(255)
  contingencia   Boolean? @default(false)
  cancelada_por  String?  @db.VarChar(255)
  base64         Bytes?
  filename       String?  @db.VarChar(255)
  folio_plantel  String?  @db.VarChar(255)
  aplicable      String?  @db.VarChar(255)
  depurado       Boolean  @default(false)
  depurado_por   String?  @db.VarChar(255)
  depurado_fecha DateTime? @db.DateTime(0)

  @@map("referenciasdepago")
}

model DocumentoConceptoPeriodos {
  id             Int       @id @default(autoincrement())
  documento      Int
  start_mes      Int       @default(1)
  end_mes        Int?
  concepto_id    Int?
  conceptoNombre String?   @db.VarChar(255)
  costo          Decimal?  @db.Decimal(65, 2)
  accion         String    @default("cambio") @db.VarChar(30)
  estatus        String    @default("Activo") @db.VarChar(30)
  created_at     DateTime  @default(now()) @db.DateTime(0)
  created_by     String?   @db.VarChar(255)

  @@index([documento, start_mes, end_mes, estatus], map: "idx_documento_periodo")
  @@map("documento_concepto_periodos")
}

model SolicitudesCancelaciones {
  id             Int      @id @default(autoincrement())
  fecha          DateTime @default(now()) @db.DateTime(0)
  folio          Int
  motivo         String   @db.Text
  monto          Int
  nombreCompleto String   @db.VarChar(255)
  conceptoNombre String   @db.VarChar(255)
  usuario        String   @db.VarChar(255)
  usuarioId      Int
  revisado_por   String?  @db.VarChar(255)
  status         String   @default("pendiente") @db.VarChar(255)

  @@map("solicitudescancelaciones")
}

model Users {
  id         Int       @id @default(autoincrement())
  username   String    @unique(map: "username") @db.VarChar(50)
  password   String    @db.VarChar(255)
  plantel    String    @db.VarChar(255)
  created_at DateTime? @default(now()) @db.DateTime(0)
  avatar     String?   @db.VarChar(255)
  email      String?   @db.VarChar(255)
  role       String    @default("plantel") @db.VarChar(20)
  planteles  String?   @db.Text

  @@map("users")
}

